# ── API key cho các nhà cung cấp LLM ──────────────────────────────────────────
# Dev điền key tương ứng vào .env (KHÔNG commit .env lên Git).
# Người dùng cuối KHÔNG cần biết các key này.

# Groq         — https://console.groq.com
GROQ_API_KEY=

# OpenAI       — https://platform.openai.com
OPENAI_API_KEY=

# Anthropic    — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# DeepSeek    — https://platform.deepseek.com/api_keys  (OpenAI-compatible)
DEEPSEEK_API_KEY=

# ── Tuỳ chọn ──────────────────────────────────────────────────────────────────
# Provider mặc định khi nhiều key cùng được cấu hình
CHATBOT_DEFAULT_PROVIDER=groq

# GitHub repo dùng cho URL trích dẫn nguồn (mặc định: VinhTP5/ChatbotPTCTPT@main)
CHATBOT_GH_OWNER=VinhTP5
CHATBOT_GH_REPO=ChatbotPTCTPT
CHATBOT_GH_BRANCH=main
CHATBOT_GH_DATA_PREFIX=data

# Hoặc override toàn bộ domain (ghi đè 4 biến trên)
# CHATBOT_DOC_DOMAIN=https://your.cdn/docs
# CHATBOT_DOC_RAW_DOMAIN=https://your.cdn/raw

# HuggingFace token (chỉ cần nếu HF rate-limit khi tải embedding lần đầu)
HF_TOKEN=
