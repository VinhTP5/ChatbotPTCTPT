# Mẫu cấu hình Streamlit Secrets cho deploy trên Streamlit Cloud.
# Đặt vào: .streamlit/secrets.toml (KHÔNG commit file này lên Git).
# App sẽ tự động phát hiện và sử dụng — người dùng cuối không thấy/không nhập.

GROQ_API_KEY        = ""
OPENAI_API_KEY      = ""
ANTHROPIC_API_KEY   = ""
GOOGLE_API_KEY      = ""
DEEPSEEK_API_KEY    = ""

# Tuỳ chọn
CHATBOT_DEFAULT_PROVIDER = "groq"
CHATBOT_DOC_DOMAIN       = "https://chatbot-ptctpt.local/docs"
